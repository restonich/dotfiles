set number
set relativenumber
set cursorline
set clipboard=unnamedplus

set termguicolors
let g:gruvbox_contrast_dark = 'medium'
colorscheme gruvbox

set noexpandtab
set tabstop=4
set shiftwidth=4
set softtabstop=0

